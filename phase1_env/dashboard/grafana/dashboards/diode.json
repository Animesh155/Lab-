      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "InfluxDB-Diode" },
          "query": "from(bucket: \"metrics\") |> range(start: -10m) |> filter(fn: (r) => r._measurement == \"sensor_reading\" and r._field == \"value\" and (r.tag_name == \"P1_PIT01_pressure_1\" or r.tag_name == \"P1_PIT02_pressure_2\" or r.tag_name == \"P1_TIT01_temperature_1\" or r.tag_name == \"P1_TIT02_temperature_2\")) |> aggregateWindow(every: 1s, fn: mean) |> drop(columns: [\"tag_id\", \"quality\"])"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } }
    },
