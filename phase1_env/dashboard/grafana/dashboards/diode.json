      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "InfluxDB-Diode" },
          "query": "from(bucket: \"metrics\") |> range(start: -1m) |> filter(fn: (r) => r._measurement == \"diode_stats\" and r._field == \"heartbeat_state\") |> last()"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
