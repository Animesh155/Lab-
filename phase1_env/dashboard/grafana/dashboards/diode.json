        {
          "datasource": { "type": "influxdb", "uid": "InfluxDB-Diode" },
          "query": "from(bucket: \"metrics\") |> range(start: -10m) |> filter(fn: (r) => r._measurement == \"sensor_reading\" and r._field == \"value\" and (r.tag_name == \"P1_LIT01_tank_level\" or r.tag_name == \"P1_LCV01D_lvl_valve_D\" or r.tag_name == \"P1_LCV01Z_lvl_valve_Z\" or r.tag_name == \"P1_PCV01D_press_valve_D\" or r.tag_name == \"P1_PCV01Z_press_valve_Z\" or r.tag_name == \"P1_FCV03D_flow_valve_D\" or r.tag_name == \"P1_FCV03Z_flow_valve_Z\")) |> aggregateWindow(every: 1s, fn: mean) |> drop(columns: [\"tag_id\", \"quality\"])"
        }
