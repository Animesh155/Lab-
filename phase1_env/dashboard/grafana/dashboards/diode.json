    {
      "type": "timeseries",
      "title": "Stage 1 — Flow Transmitters",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "influxdb", "uid": "InfluxDB-Diode" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "InfluxDB-Diode" },
          "query": "from(bucket: \"metrics\") |> range(start: -10m) |> filter(fn: (r) => r._measurement == \"sensor_reading\" and r._field == \"value\" and (r.tag_name == \"P1_FT01_intake_flow_1\" or r.tag_name == \"P1_FT01Z_intake_flow_1z\" or r.tag_name == \"P1_FT02_transfer_flow\" or r.tag_name == \"P1_FT03_output_flow\")) |> aggregateWindow(every: 1s, fn: mean) |> drop(columns: [\"tag_id\", \"quality\"])"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries",
      "title": "Stage 1 — Pressure & Temperature",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
