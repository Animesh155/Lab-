      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "UNKNOWN",  "color": "yellow" } } },
            { "type": "value", "options": { "1": { "text": "HEALTHY",  "color": "green" } } },
            { "type": "value", "options": { "2": { "text": "SILENT (ALARM)", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }] }
